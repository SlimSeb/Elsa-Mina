<Application
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:setup="clr-namespace:ElsaMina.Gui.Pages.Setup"
    xmlns:dashboard="clr-namespace:ElsaMina.Gui.Pages.Dashboard"
    x:Class="ElsaMina.Gui.App"
    RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type setup:SetupViewModel}">
            <setup:SetupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type dashboard:DashboardViewModel}">
            <dashboard:DashboardView />
        </DataTemplate>
    </Application.DataTemplates>

</Application>