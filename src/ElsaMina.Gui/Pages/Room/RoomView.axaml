<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ElsaMina.Gui.Pages.Room"
             x:DataType="vm:RoomViewModel"
             x:Class="ElsaMina.Gui.Pages.Room.RoomView">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,10"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                        Classes="icon-btn" ToolTip.Tip="Back to dashboard">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="12" Height="12"
                                  Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RoomName}" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="{Binding RoomId, StringFormat='({0})'}" Opacity="0.45" FontSize="12"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}"
                        Classes="icon-btn" IsEnabled="{Binding !IsLoading}"/>

            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- Left: Users -->
            <Border Grid.Column="0" Padding="16,12,16,0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                <Grid RowDefinitions="Auto,*">

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                        <TextBlock Text="USERS" Classes="section-header" Margin="0"/>
                        <TextBlock Text="{Binding UserCount, StringFormat='({0})'}"
                                   FontSize="10" Opacity="0.4" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Users}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RoomUserViewModel">
                                    <DockPanel Margin="0,2" LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding RankSymbol}"
                                                   FontFamily="Courier New, Consolas, monospace"
                                                   FontSize="12"
                                                   Width="16"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   Opacity="{Binding NameOpacity}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>
            </Border>

            <!-- Right: Parameters -->
            <Border Grid.Column="1" Padding="16,12,16,0">
                <Grid RowDefinitions="Auto,*">

                    <TextBlock Grid.Row="0" Text="ROOM PARAMETERS" Classes="section-header"/>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Parameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RoomParameterViewModel">
                                    <Border Padding="0,6" BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding Name}"
                                                       Width="180"
                                                       FontSize="12"
                                                       Opacity="0.7"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
