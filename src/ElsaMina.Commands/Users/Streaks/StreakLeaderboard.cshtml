@using ElsaMina.Core.Services.Templates
@using ElsaMina.Core.Utils
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Users.Streaks.StreakLeaderboardViewModel>

@{
    const string headerStyle = $"border-bottom: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR}; padding: 4px";
}
<div style="max-height: 200px; overflow-y: auto">
    <table style="margin: auto; border: 1px solid @StyleConstants.PRIMARY_BORDER_COLOR; border-radius: 12px; padding: 4px">
        <thead>
        <tr>
            <th colspan="4" scope="colgroup">
                @GetString("streak_leaderboard_title", Model.Room)
            </th>
        </tr>
        <tr>
            <th scope="col" style="@headerStyle">#</th>
            <th scope="col" style="@headerStyle">@GetString("streak_leaderboard_user")</th>
            <th scope="col" style="@headerStyle">@GetString("streak_leaderboard_current")</th>
            <th scope="col" style="@headerStyle">@GetString("streak_leaderboard_longest")</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var entry in Model.TopList)
        {
            <tr>
                <td style="text-align: center">@entry.Rank</td>
                <td style="text-align: center; color: @entry.UserId.ToColorHexCodeWithCustoms()">@entry.UserName</td>
                <td style="text-align: center">@entry.CurrentStreak</td>
                <td style="text-align: center">@entry.LongestStreak</td>
            </tr>
        }
        </tbody>
    </table>
</div>
