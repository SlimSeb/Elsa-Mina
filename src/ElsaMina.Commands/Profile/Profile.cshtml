@using ElsaMina.Core.Utils
@using ElsaMina.DataAccess.Models
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Profile.ProfileViewModel>

@{
    var bgColor = !string.IsNullOrEmpty(Model.ProfileBackgroundColor)
        ? Model.ProfileBackgroundColor
        : "#1a1a2e";

    var rankNameKey = Model.UserRoomRank switch
    {
        '~' => "rank_administrator",
        '&' => "rank_leader",
        '#' => "rank_owner",
        '*' => "rank_bot",
        '@' => "rank_mod",
        '^' => "rank_prizewinner",
        '%' => "rank_driver",
        '+' => "rank_voice",
        '★' => "rank_host",
        '♡' => "rank_former_staff",
        _ => null
    };
}

<div style="display:inline-block;background:#1a1a2e;border-radius:6px;padding:1px;">
<table style="border-collapse:collapse;background:@bgColor;border-radius:6px;font-size:11px;color:#e0e0e0;font-family:monospace;">
    <tbody>
    <tr>
        <td style="padding:8px 8px 8px 10px;vertical-align:top;width:48px;text-align:center;">
            <img
                class="pixelated"
                width="48"
                height="48"
                src="@Model.Avatar"
                alt="@Model.UserName Avatar"
                style="display:block;border-radius:3px;"/>
            @if (Model.Badges != null && Model.Badges.Any())
            {
                <div style="margin-top:4px;text-align:center;">
                    @foreach (var badge in Model.Badges)
                    {
                        <span style="display:inline-block;margin:1px;">
                            @{ await IncludeAsync("Badges/Badge", badge); }
                        </span>
                    }
                </div>
            }
        </td>
        <td style="padding:8px 12px 8px 4px;vertical-align:top;">
            <div style="margin-bottom:4px;">
                <span
                    class="username"
                    data-name="@Model.UserId"
                    style="font-weight:bold;font-size:12px;color:@Model.UserId.ToColorHexCodeWithCustoms();">
                    @Model.UserName
                </span>
                @if (!string.IsNullOrEmpty(Model.ProfileEmoji))
                {
                    <span style="font-size:1.1em;">@Raw(Model.ProfileEmoji)</span>
                }
                @if (!string.IsNullOrEmpty(rankNameKey))
                {
                    <span style="color:#a0a0c0;font-size:10px;">(@GetString(rankNameKey))</span>
                }
                @if (Model.IsOnline)
                {
                    <span style="color:#4caf50;">&#9679;</span>
                }
            </div>

            @if (!Model.IsOnline && Model.LastSeenDate.HasValue && Model.LastSeenAction.HasValue)
            {
                var actionKey = Model.LastSeenAction.Value switch
                {
                    UserAction.Leaving => "seen_command_action_leaving",
                    UserAction.Joining => "seen_command_action_joining",
                    UserAction.Chatting => "seen_command_action_chatting",
                    _ => null
                };
                <div style="margin-bottom:2px;">
                    <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_last_seen"):</span>
                    <span>@Model.LastSeenDate.Value.ToString("g", Model.Culture)
                        @if (!string.IsNullOrEmpty(actionKey))
                        {
                            <span>(@GetString(actionKey))</span>
                        }
                    </span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Status))
            {
                <div style="margin-bottom:2px;">
                    <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_status"):</span>
                    <span>@Model.Status</span>
                </div>
            }

            @if (Model.RegisterDate > DateTimeOffset.MinValue)
            {
                <div style="margin-bottom:2px;">
                    <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_register_date"):</span>
                    <span>@Model.RegisterDate.ToString("d", Model.Culture)</span>
                </div>
            }

            @if (Model.PlayTime > TimeSpan.Zero)
            {
                <div style="margin-bottom:2px;">
                    <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_play_time"):</span>
                    <span>@Model.PlayTime.ToString(GetString("play_time_format"))</span>
                </div>
            }

            @if (Model.BestRanking != null)
            {
                <div style="margin-bottom:2px;">
                    <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_best_rank"):</span>
                    <span>@Model.BestRanking.FormatId (@Model.BestRanking.Elo.ToString("F0", Model.Culture))</span>
                </div>
            }

            @if (Model.TournamentRecord != null && Model.TournamentRecord.TournamentsEnteredCount > 0)
            {
                var record = Model.TournamentRecord;
                var wl = record.PlayedGames > 0
                    ? GetString("profile_tournament_wl", record.WonGames, record.PlayedGames - record.WonGames)
                    : "-";
                <div style="margin-bottom:2px;">
                    <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_tournament_records"):</span>
                    <span>
                        <span title="@GetString("top_tournament_players_wins")">🏆 @record.WinsCount</span>
                        ·
                        <span title="@GetString("top_tournament_players_runner_up")">🥈 @record.RunnerUpCount</span>
                        ·
                        <span title="@GetString("top_tournament_players_third_place")">🥉 @record.ThirdPlaceCount</span>
                        ·
                        <span title="@GetString("top_tournament_players_win_rate")">@wl</span>
                        ·
                        <span title="@GetString("top_tournament_players_entered")">(@record.TournamentsEnteredCount)</span>
                    </span>
                </div>
            }

            @if (Model.GameRecords != null && Model.GameRecords.HasAnyRecord)
            {
                var gr = Model.GameRecords;
                <div style="margin-top:4px;border-top:1px solid #2e2e4e;padding-top:4px;">
                    @if (gr.FloodIt != null)
                    {
                        <div style="margin-bottom:2px;">
                            <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_flood_it"):</span>
                            <span>
                                <span title="@GetString("profile_game_max_level")">Lv. @gr.FloodIt.Level</span>
                                · <span title="@GetString("profile_game_total_stars")">⭐ @gr.FloodIt.TotalStars</span>
                            </span>
                        </div>
                    }
                    @if (gr.LightsOut != null)
                    {
                        <div style="margin-bottom:2px;">
                            <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_lights_out"):</span>
                            <span>
                                <span title="@GetString("profile_game_max_level")">Lv. @gr.LightsOut.Level</span>
                                · <span title="@GetString("profile_game_total_stars")">⭐ @gr.LightsOut.TotalStars</span>
                            </span>
                        </div>
                    }
                    @if (gr.VoltorbFlip != null)
                    {
                        <div style="margin-bottom:2px;">
                            <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_voltorb_flip"):</span>
                            <span>
                                <span title="@GetString("profile_game_max_level")">Lv. @gr.VoltorbFlip.MaxLevel</span>
                                · <span title="@GetString("profile_game_coins")">💰 @gr.VoltorbFlip.Coins</span>
                            </span>
                        </div>
                    }
                    @if (gr.TwentyFortyEight != null)
                    {
                        <div style="margin-bottom:2px;">
                            <span style="color:#6a9fd8;font-weight:bold;">@GetString("profile_2048"):</span>
                            <span>
                                <span title="@GetString("profile_game_best_score")">@gr.TwentyFortyEight.BestScore</span>
                                · <span title="@GetString("profile_game_wins")">🏆 @gr.TwentyFortyEight.Wins</span>
                            </span>
                        </div>
                    }
                    @if (gr.ConnectFour != null)
                    {
                        <div style="margin-bottom:2px;">
                            <span style="color:#6a9fd8;font-weight:bold;">@GetString("c4_game_name"):</span>
                            <span>
                                <span title="@GetString("c4_leaderboard_rating")">@gr.ConnectFour.Rating</span>
                                · <span title="@GetString("c4_leaderboard_wins")">🏆 @gr.ConnectFour.Wins</span>
                                · <span title="@GetString("c4_leaderboard_losses")">💀 @gr.ConnectFour.Losses</span>
                                @if (gr.ConnectFour.Draws > 0)
                                {
                                    <span>· <span title="@GetString("c4_leaderboard_draws")">🤝 @gr.ConnectFour.Draws</span></span>
                                }
                            </span>
                        </div>
                    }
                </div>
            }

            <div style="margin-top:4px;border-top:1px solid #2e2e4e;padding-top:4px;">
                @if (!string.IsNullOrEmpty(Model.Title))
                {
                    <span style="color:#a0a0c0;font-size:10px;font-style:italic;">@Raw(Model.Title)</span>
                }
                else
                {
                    <span style="font-style:italic;color:#606080;font-size:10px;">@GetString("profile_no_title")</span>
                }
            </div>
        </td>
    </tr>
    </tbody>
</table>
</div>
