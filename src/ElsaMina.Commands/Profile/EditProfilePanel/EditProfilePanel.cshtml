@using ElsaMina.Commands.Profile.EditProfilePanel
@using ElsaMina.Core.Services.Templates
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Profile.EditProfilePanel.EditProfilePanelViewModel>

@{
    const string containerStyle = "padding: 1.5rem; max-width: 700px;";
    const string sectionStyle = $"border: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR};" +
                                "padding: .75rem 1rem;" +
                                "margin-bottom: 1rem;" +
                                $"background-color: {StyleConstants.PRIMARY_BACKGROUND_COLOR};";
    const string sectionTitleStyle = "font-weight: bold; margin-bottom: .5rem;";
    const string currentEmojiStyle = "font-size: 1.6em; margin-left: .5rem; vertical-align: middle;";
    const string colorSwatchStyle = "display: inline-block; width: 20px; height: 20px; border-radius: 3px;" +
                                    $"border: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR}; vertical-align: middle; margin-right: 4px;";

    var flags = EditProfilePanelCommand.GetAllCountryFlags().ToList();
}

<div style="@containerStyle">
    <h2>@GetString("edit_profile_panel_title")</h2>

    <div style="@sectionStyle">
        <div style="@sectionTitleStyle">@GetString("edit_profile_panel_emoji_section")</div>
        <div>
            <span>@GetString("edit_profile_panel_current_emoji")</span>
            @if (!string.IsNullOrEmpty(Model.CurrentEmoji))
            {
                <span style="@currentEmojiStyle">@Model.CurrentEmoji</span>
                <button
                    class="button"
                    name="send"
                    value="/w @Model.BotName,@(Model.Trigger)clearemoji @Model.RoomId"
                    style="margin-left: .5rem; vertical-align: middle;">
                    @GetString("edit_profile_panel_clear")
                </button>
            }
            else
            {
                <em style="margin-left: .5rem;">@GetString("edit_profile_panel_no_emoji")</em>
            }
        </div>
        <form data-submitsend="/w @Model.BotName,@(Model.Trigger)setemoji @Model.RoomId, {flag}" style="margin-top: .5rem;">
            <select name="flag" class="textbox">
                @foreach (var (_, flag, name) in flags)
                {
                    <option value="@Raw(flag)">@flag @name</option>
                }
            </select>
            <button class="button" type="submit" style="margin-left: .35rem;">@GetString("submit")</button>
        </form>
    </div>

    <div style="@sectionStyle">
        <div style="@sectionTitleStyle">@GetString("edit_profile_panel_bg_color_section")</div>
        <div style="margin-bottom: .4rem;">
            <span>@GetString("edit_profile_panel_current_emoji")</span>
            @if (!string.IsNullOrEmpty(Model.CurrentBackgroundColor))
            {
                <span style="@colorSwatchStyle background: @Model.CurrentBackgroundColor;"></span>
            }
            else
            {
                <em style="margin-left: .5rem;">@GetString("edit_profile_panel_no_color")</em>
            }
        </div>
        <table style="border-collapse: separate; border-spacing: .3rem; margin-top: .35rem; table-layout: fixed; width: 100%;">
            <tbody>
                @{
                    const int colorColumns = 3;
                    var colorEntries = EditProfilePanelCommand.PROFILE_COLORS
                        .Select(kvp => (kvp.Key, kvp.Value))
                        .Append((Key: string.Empty, Value: string.Empty))
                        .ToList();
                }
                @for (var i = 0; i < colorEntries.Count; i += colorColumns)
                {
                    <tr>
                        @for (var j = i; j < Math.Min(i + colorColumns, colorEntries.Count); j++)
                        {
                            var (colorKey, colorValue) = colorEntries[j];
                            var isClear = string.IsNullOrEmpty(colorKey);
                            var sendValue = isClear
                                ? $"/w {Model.BotName},{Model.Trigger}clearprofilecolor {Model.RoomId}"
                                : $"/w {Model.BotName},{Model.Trigger}setprofilecolor {Model.RoomId}, {colorKey}";
                            var swatchBg = isClear ? "transparent" : colorValue;
                            var label = isClear ? GetString("edit_profile_panel_clear") : GetString($"color_{colorKey}");
                            <td>
                                <button
                                    class="button"
                                    name="send"
                                    value="@sendValue"
                                    style="display: flex; align-items: center; gap: 5px; width: 100%;">
                                    <span style="@colorSwatchStyle background: @swatchBg; margin-right: 0; flex-shrink: 0;"></span>
                                    @label
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
