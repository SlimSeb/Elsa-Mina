@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Belote.BeloteViewModel>
@using ElsaMina.Commands.Games.Belote
@using ElsaMina.Core.Utils

@{
    var game = Model.Game;

    string CardColor(BeloteCard card) =>
        card.Suit is BeloteSuit.Hearts or BeloteSuit.Diamonds ? "#ff7b7b" : "#ececec";

    string SuitColor(BeloteSuit suit) =>
        suit is BeloteSuit.Hearts or BeloteSuit.Diamonds ? "#ff7b7b" : "#ececec";

    string TeamName(int team) => GetString(team == 0 ? "belote_team_one" : "belote_team_two");
}

<div style="background:#1f3326;color:#e6f2ea;border:1px solid #3f6a4f;border-radius:6px;padding:8px">
    <h3 style="margin:0 0 6px 0;text-align:center">🃏 @GetString("belote_title")</h3>

    @if (game.Phase == BelotePhase.Bidding)
    {
        <p style="text-align:center;margin:4px 0">
            <b>@GetString("belote_bidding_phase", game.BiddingRound)</b>
        </p>
        <p style="text-align:center;margin:4px 0">
            @GetString("belote_turned_card_label"):
            <span style="color:@CardColor(game.TurnedCard);font-weight:bold;font-size:1.3em">@game.TurnedCard.ToDisplay(Model.Culture)</span>
            @if (game.BiddingRound == 2)
            {
                <text>&nbsp;<span style="color:#bbb;font-size:0.85em">(@GetString("belote_turned_card_refused"))</span></text>
            }
        </p>
        <table style="margin:auto;border-collapse:collapse">
            @foreach (var player in game.Players)
            {
                var isCurrent = game.CurrentPlayer == player;
                <tr style="@(isCurrent ? "font-weight:bold;background:#2c4a38" : "")">
                    <td style="padding:2px 10px;color:@player.Name.ToColorHexCodeWithCustoms()">@player.Name</td>
                    <td style="padding:2px 10px;color:#9fc4ad;font-size:0.85em">@TeamName(player.Team)</td>
                    <td style="padding:2px 10px">
                        @if (player.HasBid)
                        {
                            <text>@GetString("belote_bid_passed")</text>
                        }
                        else if (isCurrent)
                        {
                            <em>@GetString("belote_bidding_thinking")</em>
                        }
                        else
                        {
                            <text>&mdash;</text>
                        }
                    </td>
                </tr>
            }
        </table>
    }
    else if (game.Phase == BelotePhase.Playing && game.Trump != null)
    {
        var trump = game.Trump.Value;
        <p style="text-align:center;margin:4px 0">
            <b>@GetString("belote_taker_label"):</b>
            <span style="color:@game.Taker?.Name.ToColorHexCodeWithCustoms()">@game.Taker?.Name</span>
            &nbsp;|&nbsp; <b>@GetString("belote_trump_label"):</b>
            <span style="color:@SuitColor(trump);font-weight:bold;font-size:1.2em">@BeloteCard.SuitDisplay(trump)</span>
            @GetString($"belote_suit_{trump.ToString().ToLowerInvariant()}")
        </p>

        <p style="text-align:center;margin:4px 0;color:#bfe0cd">
            <b>@TeamName(0)</b> (@GetString("belote_tricks_count", game.Team0Tricks))
            &nbsp;|&nbsp;
            <b>@TeamName(1)</b> (@GetString("belote_tricks_count", game.Team1Tricks))
        </p>

        @if (game.LastTrick != null && game.LastTrickWinner != null)
        {
            <p style="text-align:center;margin:8px 0 2px 0;color:#a9c9b6;font-size:0.85em">
                @GetString("belote_last_trick_label") : @GetString("belote_won_by", game.LastTrickWinner.Name)
            </p>
            <p style="text-align:center;margin:0 0 6px 0">
                @foreach (var (player, card) in game.LastTrick.Plays)
                {
                    var isWinningCard = player == game.LastTrickWinner;
                    <span style="display:inline-block;margin:0 5px;text-align:center;opacity:@(isWinningCard ? "1" : "0.55")">
                        <span style="color:@CardColor(card);font-weight:bold;font-size:1.15em">@card.ToDisplay(Model.Culture)</span><br>
                        <span style="font-size:0.7em;color:#8caa9a">@player.Name@(isWinningCard ? " 🏆" : "")</span>
                    </span>
                }
            </p>
        }

        <p style="text-align:center;margin:8px 0 2px 0;color:#a9c9b6">
            @GetString("belote_trick_progress", game.TrickNumber, game.TotalTricks)
        </p>
        @if (game.CurrentTrick.Plays.Count > 0)
        {
            <p style="text-align:center;margin:0 0 4px 0">
                @for (var i = 0; i < game.CurrentTrick.Plays.Count; i++)
                {
                    var (player, card) = game.CurrentTrick.Plays[i];
                    var isLast = i == game.CurrentTrick.Plays.Count - 1;
                    <span style="display:inline-block;margin:0 6px;text-align:center;padding:3px 6px;border-radius:5px;@(isLast ? "background:#2c4a38;box-shadow:0 0 0 2px #f7d774" : "")">
                        <span style="color:@CardColor(card);font-weight:bold;font-size:1.15em">@card.ToDisplay(Model.Culture)</span><br>
                        <span style="font-size:0.7em;color:#bbd9c8">@player.Name@(isLast ? " ◀" : "")</span>
                    </span>
                }
            </p>
        }
        @if (game.CurrentPlayer != null)
        {
            <p style="text-align:center;margin:6px 0 0 0">
                @GetString("belote_waiting_for")
                <b style="color:@game.CurrentPlayer.Name.ToColorHexCodeWithCustoms()">@game.CurrentPlayer.Name</b>
            </p>
        }
    }
</div>
