@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Belote.BeloteViewModel>
@using ElsaMina.Commands.Games.Belote
@using ElsaMina.Core.Utils

@{
    var game = Model.Game;
    var viewer = Model.Viewer;
    var isViewerTurn = game.CurrentPlayer == viewer;
    var trump = game.Trump;

    string CardColor(BeloteCard card) =>
        card.Suit is BeloteSuit.Hearts or BeloteSuit.Diamonds ? "#cc2b2b" : "#111";

    bool IsTrumpCard(BeloteCard card) => trump != null && card.Suit == trump.Value;

    string BidAction(string argument) =>
        $"/w {Model.BotName}, {Model.Trigger}bb {Model.RoomId}, {argument}";

    string PlayAction(BeloteCard card) =>
        $"/w {Model.BotName}, {Model.Trigger}bp {Model.RoomId}, {card.ToToken()}";
}

<div style="background:#152119;color:#e6f2ea;border:1px solid #3f6a4f;border-radius:6px;padding:8px">
    <h4 style="margin:0 0 6px 0">🃏 @GetString("belote_your_hand")</h4>

    @if (game.Phase == BelotePhase.Bidding && isViewerTurn)
    {
        <p style="margin:4px 0">
            @GetString("belote_turned_card_label"):
            <span style="font-weight:bold;font-size:1.2em;color:@CardColor(game.TurnedCard)">@game.TurnedCard.ToDisplay(Model.Culture)</span>
        </p>
        @if (game.BiddingRound == 1)
        {
            <p style="margin:4px 0">@GetString("belote_your_turn_bid_one", BeloteCard.SuitDisplay(game.TurnedCard.Suit))</p>
            <p style="margin:4px 0">
                <button class="button" name="send" value="@BidAction("take")">@GetString("belote_bid_take_button")</button>
                <button class="button" name="send" value="@BidAction("pass")">@GetString("belote_bid_pass_button")</button>
            </p>
        }
        else
        {
            <p style="margin:4px 0">@GetString("belote_your_turn_bid_two")</p>
            <p style="margin:4px 0">
                @foreach (var suit in ElsaMina.Commands.Games.Belote.BeloteConstants.Suits)
                {
                    if (suit == game.TurnedCard.Suit)
                    {
                        continue;
                    }
                    var color = suit is BeloteSuit.Hearts or BeloteSuit.Diamonds ? "#cc2b2b" : "#111";
                    <button class="button" name="send" value="@BidAction(BeloteCard.SuitToken(suit))" style="color:@color">
                        @BeloteCard.SuitDisplay(suit) @GetString($"belote_suit_{suit.ToString().ToLowerInvariant()}")
                    </button>
                }
                <button class="button" name="send" value="@BidAction("pass")">@GetString("belote_bid_pass_button")</button>
            </p>
        }
    }

    @if (game.Phase == BelotePhase.Playing && game.LastPlayedCard != null)
    {
        <p style="margin:2px 0;color:#bfe0cd;font-size:0.85em">
            @GetString("belote_last_played_label"):
            <b style="color:@CardColor(game.LastPlayedCard)">@game.LastPlayedCard.ToDisplay(Model.Culture)</b>
        </p>
    }

    <p style="margin:6px 0;line-height:2.4em">
        @foreach (var card in Model.ViewerHand)
        {
            var color = CardColor(card);
            var trumpStyle = IsTrumpCard(card) ? "box-shadow:0 0 0 2px #f7d774;" : "";
            var baseStyle = $"display:inline-block;margin:2px;padding:3px 6px;font-size:1.05em;font-weight:bold;border-radius:4px;background:#f3f8f4;color:{color};{trumpStyle}";
            if (game.Phase == BelotePhase.Playing && isViewerTurn)
            {
                if (Model.ViewerLegalMoves.Contains(card))
                {
                    <button name="send" value="@PlayAction(card)" style="@baseStyle;cursor:pointer">@card.ToDisplay(Model.Culture)</button>
                }
                else
                {
                    <span style="@baseStyle;opacity:0.35">@card.ToDisplay(Model.Culture)</span>
                }
            }
            else
            {
                <span style="@baseStyle">@card.ToDisplay(Model.Culture)</span>
            }
        }
    </p>

    @if (game.Phase == BelotePhase.Playing && !isViewerTurn && game.CurrentPlayer != null)
    {
        <p style="margin:4px 0;color:#8caa9a;font-size:0.85em">
            @GetString("belote_waiting_for") <b>@game.CurrentPlayer.Name</b>
        </p>
    }

    <details style="margin:8px 0 0 0">
        <summary style="cursor:pointer;font-size:0.8em;color:#8caa9a">@GetString("belote_options")</summary>
        <p style="margin:8px 0 0 0;text-align:right">
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)belotesub @Model.RoomId" style="font-size:0.8em">
                @(viewer != null && viewer.WantsSub ? GetString("belote_sub_cancel_button") : GetString("belote_sub_request_button"))
            </button>
        </p>
    </details>
</div>
