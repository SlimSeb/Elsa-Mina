@using ElsaMina.Core.Services.Templates
@using ElsaMina.Core.Utils
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Semantix.SemantixLeaderboardViewModel>
@{
    const string headerStyle = $"border-bottom: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR}; padding: 4px";
}
<div style="max-height: 200px; overflow-y: auto">
    <table style="margin: auto; border: 1px solid @StyleConstants.PRIMARY_BORDER_COLOR; border-radius: 12px; padding: 4px">
        <thead>
        <tr>
            <th colspan="6" scope="colgroup">@GetString("sx_leaderboard_title")</th>
        </tr>
        <tr>
            <th scope="col" style="@headerStyle">#</th>
            <th scope="col" style="@headerStyle">@GetString("leaderboard_user")</th>
            <th scope="col" style="@headerStyle">@GetString("sx_leaderboard_wins")</th>
            <th scope="col" style="@headerStyle">@GetString("sx_leaderboard_streak")</th>
            <th scope="col" style="@headerStyle">@GetString("sx_leaderboard_max_streak")</th>
            <th scope="col" style="@headerStyle">@GetString("sx_leaderboard_best")</th>
        </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Leaderboard.Count; i++)
        {
            var entry = Model.Leaderboard[i];
            <tr>
                <td style="text-align:center">@(i + 1)</td>
                <td style="color: @entry.UserId.ToColorHexCodeWithCustoms()">@entry.UserId</td>
                <td style="text-align:center">@entry.Wins</td>
                <td style="text-align:center">@entry.CurrentStreak</td>
                <td style="text-align:center">@entry.MaxStreak</td>
                <td style="text-align:center">@entry.BestGuessCount</td>
            </tr>
        }
        </tbody>
    </table>
</div>
