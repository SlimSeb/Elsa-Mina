@using ElsaMina.Core.Services.Templates
@using ElsaMina.Commands.Games.Wordle
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Wordle.WordleModel>

@{
    var game = Model.CurrentGame;

    const string correctStyle = "background-color: #6aaa64; border: 1px solid #6aaa64;";
    const string presentStyle = "background-color: #c9b458; border: 1px solid #c9b458;";
    const string absentStyle = "background-color: #787c7e; border: 1px solid #787c7e;";
    const string emptyStyle = "background-color: transparent; border: 1px solid #d3d6da;";

    Func<WordleLetterState, string> tileStyle = state => state switch
    {
        WordleLetterState.Correct => correctStyle,
        WordleLetterState.Present => presentStyle,
        WordleLetterState.Absent => absentStyle,
        _ => emptyStyle
    };

    var summary = game.Owner != null
        ? $"{GetString("wordle_panel_player", game.Owner.Name)} &mdash; {GetString("wordle_panel_guesses", game.Guesses.Count, game.MaxGuesses)}"
        : GetString("wordle_panel_title");
}

<details style="border: 1px solid @StyleConstants.PRIMARY_BORDER_COLOR; border-radius: 6px; padding: 4px 8px; margin: 2px 0;">
    <summary style="cursor: pointer; font-weight: bold;">
        @Raw(summary)
        @if (game.IsWon)
        {
            <span style="color: #6aaa64;"> &#10004;</span>
        }
        else if (!game.IsRoundActive)
        {
            <span style="color: #787c7e;"> &#10008;</span>
        }
    </summary>
    <div style="text-align: center; padding-top: 6px;">
        <table style="border-collapse: separate; border-spacing: 3px; margin: auto;">
            @for (var row = 0; row < game.MaxGuesses; row++)
            {
                <tr>
                    @for (var col = 0; col < game.WordLength; col++)
                    {
                        var style = emptyStyle;
                        if (row < game.Guesses.Count)
                        {
                            style = tileStyle(game.Guesses[row].States[col]);
                        }
                        <td>
                            <div style="width: 22px; height: 22px; border-radius: 3px; @style"></div>
                        </td>
                    }
                </tr>
            }
        </table>
        @if (game.IsWon)
        {
            <div style="color: #6aaa64; font-weight: bold; margin-top: 4px;">@GetString("wordle_panel_solved", game.Guesses.Count)</div>
        }
        else if (!game.IsRoundActive)
        {
            <div style="font-weight: bold; margin-top: 4px;">@GetString("wordle_panel_not_solved")</div>
        }
    </div>
</details>
