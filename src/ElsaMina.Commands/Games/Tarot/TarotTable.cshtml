@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Tarot.TarotViewModel>
@using ElsaMina.Commands.Games.Tarot
@using ElsaMina.Core.Utils

@{
    var game = Model.Game;

    string CardColor(TarotCard card)
    {
        if (card.IsExcuse)
        {
            return "#8fd694";
        }
        if (card.IsTrump)
        {
            return "#7fc4ff";
        }
        return card.Suit is TarotSuit.Hearts or TarotSuit.Diamonds ? "#ff7b7b" : "#ececec";
    }

    string CardSize(TarotCard card) => card.IsExcuse ? "1.45em" : "1.15em";
}

<div style="background:#2d2535;color:#ece7f2;border:1px solid #5a4a6a;border-radius:6px;padding:8px">
    <h3 style="margin:0 0 6px 0;text-align:center">🃏 @GetString("tarot_title")</h3>

    @if (game.Phase == TarotPhase.Bidding)
    {
        <p style="text-align:center;margin:4px 0"><b>@GetString("tarot_bidding_phase")</b></p>
        <table style="margin:auto;border-collapse:collapse">
            @foreach (var player in game.Players)
            {
                var isCurrent = game.CurrentPlayer == player;
                <tr style="@(isCurrent ? "font-weight:bold;background:#473a57" : "")">
                    <td style="padding:2px 10px;color:@player.Name.ToColorHexCodeWithCustoms()">@player.Name</td>
                    <td style="padding:2px 10px">
                        @if (player.HasBid)
                        {
                            <text>@GetString($"tarot_bid_{player.Bid.ToString().ToLowerInvariant()}")</text>
                        }
                        else if (isCurrent)
                        {
                            <em>@GetString("tarot_bidding_thinking")</em>
                        }
                        else
                        {
                            <text>&mdash;</text>
                        }
                    </td>
                </tr>
            }
        </table>
    }
    else if (game.Phase == TarotPhase.KingCall)
    {
        <p style="text-align:center;margin:4px 0">@GetString("tarot_kingcall_phase", game.Taker?.Name)</p>
    }
    else if (game.Phase == TarotPhase.Discard)
    {
        <p style="text-align:center;margin:4px 0">@GetString("tarot_discard_phase", game.Taker?.Name)</p>
        @if (game.DogRevealed)
        {
            <p style="text-align:center;margin:4px 0">
                <b>@GetString("tarot_dog_label"):</b>
                @foreach (var card in game.Dog)
                {
                    <span style="color:@CardColor(card);font-weight:bold;font-size:@CardSize(card);margin:0 4px">@card.ToDisplay(Model.Culture)</span>
                }
            </p>
        }
    }
    else if (game.Phase == TarotPhase.Playing)
    {
        <p style="text-align:center;margin:4px 0">
            <b>@GetString("tarot_taker_label"):</b>
            <span style="color:@game.Taker?.Name.ToColorHexCodeWithCustoms()">@game.Taker?.Name</span>
            &nbsp;|&nbsp; <b>@GetString("tarot_contract_label"):</b>
            @GetString($"tarot_bid_{game.HighestBid.ToString().ToLowerInvariant()}")
            @if (game.CalledKing != null)
            {
                <text>&nbsp;|&nbsp; @GetString("tarot_called_label"): </text>
                <span style="color:@CardColor(game.CalledKing);font-weight:bold">@game.CalledKing.ToDisplay(Model.Culture)</span>
            }
        </p>
        @if (game.PartnerRevealed && game.Partner != null)
        {
            <p style="text-align:center;margin:4px 0;color:#8fd694">
                @GetString("tarot_partner_is", game.Partner.Name)
            </p>
        }

        @if (game.SlamAnnounced)
        {
            <p style="text-align:center;margin:4px 0;color:#f7d774;font-weight:bold">
                @GetString("tarot_slam_banner", game.Taker?.Name)
            </p>
        }

        @if (game.DeclaredPoignees.Count > 0)
        {
            <p style="text-align:center;margin:4px 0;color:#cabbd9;font-size:0.85em">
                @foreach (var declaration in game.DeclaredPoignees)
                {
                    <text>@GetString("tarot_poignee_banner", declaration.Player.Name, GetString($"tarot_poignee_tier_{declaration.Tier}")) </text>
                }
            </p>
        }

        @if (game.LastTrick != null && game.LastTrickWinner != null)
        {
            <p style="text-align:center;margin:8px 0 2px 0;color:#b9a9c9;font-size:0.85em">
                @GetString("tarot_last_trick_label") : @GetString("tarot_won_by", game.LastTrickWinner.Name)
            </p>
            <p style="text-align:center;margin:0 0 6px 0">
                @foreach (var (player, card) in game.LastTrick.Plays)
                {
                    var isWinningCard = player == game.LastTrickWinner;
                    <span style="display:inline-block;margin:0 5px;text-align:center;opacity:@(isWinningCard ? "1" : "0.55")">
                        <span style="color:@CardColor(card);font-weight:bold;font-size:@CardSize(card)">@card.ToDisplay(Model.Culture)</span><br>
                        <span style="font-size:0.7em;color:#9a8caa">@player.Name@(isWinningCard ? " 🏆" : "")</span>
                    </span>
                }
            </p>
        }

        <p style="text-align:center;margin:8px 0 2px 0;color:#b9a9c9">
            @GetString("tarot_trick_progress", game.TrickNumber, game.TotalTricks)
        </p>
        @if (game.CurrentTrick.Plays.Count > 0)
        {
            <p style="text-align:center;margin:0 0 4px 0">
                @for (var i = 0; i < game.CurrentTrick.Plays.Count; i++)
                {
                    var (player, card) = game.CurrentTrick.Plays[i];
                    var isLast = i == game.CurrentTrick.Plays.Count - 1;
                    <span style="display:inline-block;margin:0 6px;text-align:center;padding:3px 6px;border-radius:5px;@(isLast ? "background:#5a4a6a;box-shadow:0 0 0 2px #f7d774" : "")">
                        <span style="color:@CardColor(card);font-weight:bold;font-size:@CardSize(card)">@card.ToDisplay(Model.Culture)</span><br>
                        <span style="font-size:0.7em;color:#cabbd9">@player.Name@(isLast ? " ◀" : "")</span>
                    </span>
                }
            </p>
            @if (game.LastPlayedCard != null)
            {
                <p style="text-align:center;margin:0;color:#f7d774;font-size:0.8em">
                    @GetString("tarot_last_played_label"): <b>@game.LastPlayedCard.ToDisplay(Model.Culture)</b>
                </p>
            }
        }
        @if (game.CurrentPlayer != null)
        {
            <p style="text-align:center;margin:6px 0 0 0">
                @GetString("tarot_waiting_for")
                <b style="color:@game.CurrentPlayer.Name.ToColorHexCodeWithCustoms()">@game.CurrentPlayer.Name</b>
            </p>
        }
    }
</div>
