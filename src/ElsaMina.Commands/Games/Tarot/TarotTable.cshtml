@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Tarot.TarotViewModel>
@using ElsaMina.Commands.Games.Tarot
@using ElsaMina.Core.Utils

@{
    var game = Model.Game;

    string CardColor(TarotCard card)
    {
        if (card.IsExcuse)
        {
            return "#7a3";
        }
        if (card.IsTrump)
        {
            return "#36c";
        }
        return card.Suit is TarotSuit.Hearts or TarotSuit.Diamonds ? "#d33" : "#111";
    }
}

<div style="background:#f4f1f7;border:1px solid #b9a9c9;border-radius:6px;padding:8px">
    <h3 style="margin:0 0 6px 0;text-align:center;color:#3a2d4a">🃏 @GetString("tarot_title")</h3>

    @if (game.Phase == TarotPhase.Bidding)
    {
        <p style="text-align:center;margin:4px 0"><b>@GetString("tarot_bidding_phase")</b></p>
        <table style="margin:auto;border-collapse:collapse">
            @foreach (var player in game.Players)
            {
                var isCurrent = game.CurrentPlayer == player;
                <tr style="@(isCurrent ? "font-weight:bold;background:#e7dcf2" : "")">
                    <td style="padding:2px 10px;color:@player.Name.ToColorHexCodeWithCustoms()">@player.Name</td>
                    <td style="padding:2px 10px">
                        @if (player.HasBid)
                        {
                            <text>@GetString($"tarot_bid_{player.Bid.ToString().ToLowerInvariant()}")</text>
                        }
                        else if (isCurrent)
                        {
                            <em>@GetString("tarot_bidding_thinking")</em>
                        }
                        else
                        {
                            <text>&mdash;</text>
                        }
                    </td>
                </tr>
            }
        </table>
    }
    else if (game.Phase == TarotPhase.KingCall)
    {
        <p style="text-align:center;margin:4px 0">@GetString("tarot_kingcall_phase", game.Taker?.Name)</p>
    }
    else if (game.Phase == TarotPhase.Discard)
    {
        <p style="text-align:center;margin:4px 0">@GetString("tarot_discard_phase", game.Taker?.Name)</p>
        @if (game.DogRevealed)
        {
            <p style="text-align:center;margin:4px 0">
                <b>@GetString("tarot_dog_label"):</b>
                @foreach (var card in game.Dog)
                {
                    <span style="color:@CardColor(card);font-weight:bold;margin:0 3px">@card.ToDisplay()</span>
                }
            </p>
        }
    }
    else if (game.Phase == TarotPhase.Playing)
    {
        <p style="text-align:center;margin:4px 0">
            <b>@GetString("tarot_taker_label"):</b>
            <span style="color:@game.Taker?.Name.ToColorHexCodeWithCustoms()">@game.Taker?.Name</span>
            &nbsp;|&nbsp; <b>@GetString("tarot_contract_label"):</b>
            @GetString($"tarot_bid_{game.HighestBid.ToString().ToLowerInvariant()}")
            @if (game.CalledKing != null)
            {
                <text>&nbsp;|&nbsp; @GetString("tarot_called_label"): </text>
                <span style="color:@CardColor(game.CalledKing);font-weight:bold">@game.CalledKing.ToDisplay()</span>
            }
        </p>
        @if (game.PartnerRevealed && game.Partner != null)
        {
            <p style="text-align:center;margin:4px 0;color:#693">
                @GetString("tarot_partner_is", game.Partner.Name)
            </p>
        }
        <p style="text-align:center;margin:4px 0;color:#666">
            @GetString("tarot_trick_progress", game.TrickNumber, game.TotalTricks)
        </p>
        <table style="margin:auto;border-collapse:collapse">
            @foreach (var (player, card) in game.CurrentTrick.Plays)
            {
                <tr>
                    <td style="padding:2px 10px;color:@player.Name.ToColorHexCodeWithCustoms()">@player.Name</td>
                    <td style="padding:2px 10px;font-size:1.2em;font-weight:bold;color:@CardColor(card)">@card.ToDisplay()</td>
                </tr>
            }
        </table>
        @if (game.CurrentPlayer != null)
        {
            <p style="text-align:center;margin:6px 0">
                @GetString("tarot_waiting_for")
                <b style="color:@game.CurrentPlayer.Name.ToColorHexCodeWithCustoms()">@game.CurrentPlayer.Name</b>
            </p>
        }
    }
</div>
