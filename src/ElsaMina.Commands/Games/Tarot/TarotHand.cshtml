@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Tarot.TarotViewModel>
@using ElsaMina.Commands.Games.Tarot
@using ElsaMina.Core.Utils

@{
    var game = Model.Game;
    var viewer = Model.Viewer;
    var isTaker = viewer != null && viewer.IsTaker;
    var isViewerTurn = game.CurrentPlayer == viewer;

    string CardColor(TarotCard card)
    {
        if (card.IsExcuse)
        {
            return "#3a7a3f";
        }
        if (card.IsTrump)
        {
            return "#1f6dbf";
        }
        return card.Suit is TarotSuit.Hearts or TarotSuit.Diamonds ? "#cc2b2b" : "#111";
    }

    string CardFontSize(TarotCard card) => card.IsExcuse ? "1.35em" : "1.05em";
    string CardPadding(TarotCard card) => card.IsExcuse ? "5px 8px" : "3px 6px";

    string Action(string command, TarotCard card) =>
        $"/w {Model.BotName}, {Model.Trigger}{command} {Model.RoomId}, {card.ToToken()}";
}

<div style="background:#211b29;color:#ece7f2;border:1px solid #5a4a6a;border-radius:6px;padding:8px">
    <h4 style="margin:0 0 6px 0">🃏 @GetString("tarot_your_hand")</h4>

    @if (game.Phase == TarotPhase.Bidding && isViewerTurn)
    {
        <p style="margin:4px 0">@GetString("tarot_your_turn_bid")</p>
        <p style="margin:4px 0">
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tb @Model.RoomId, pass">@GetString("tarot_bid_pass")</button>
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tb @Model.RoomId, petite">@GetString("tarot_bid_petite")</button>
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tb @Model.RoomId, garde">@GetString("tarot_bid_garde")</button>
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tb @Model.RoomId, gardesans">@GetString("tarot_bid_gardesans")</button>
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tb @Model.RoomId, gardecontre">@GetString("tarot_bid_gardecontre")</button>
        </p>
    }

    @if (game.Phase == TarotPhase.KingCall && isTaker)
    {
        <p style="margin:4px 0">@GetString("tarot_your_turn_call")</p>
        <p style="margin:4px 0">
            @foreach (var suit in new[] { "h", "s", "d", "c" })
            {
                var king = TarotCard.Parse($"k{suit}");
                <button class="button" name="send" value="@Action("tarotcall", king)" style="color:@CardColor(king)">@king.ToDisplay(Model.Culture)</button>
            }
        </p>
    }

    @if (game.Phase == TarotPhase.Discard && isTaker)
    {
        <p style="margin:4px 0">@GetString("tarot_your_turn_discard", game.PendingDiscards.Count, ElsaMina.Commands.Games.Tarot.TarotConstants.DOG_SIZE[game.PlayerCount])</p>
    }

    @if (game.Phase == TarotPhase.Playing && game.LastPlayedCard != null)
    {
        <p style="margin:2px 0;color:#c7b8d6;font-size:0.85em">
            @GetString("tarot_last_played_label"):
            <b style="color:@CardColor(game.LastPlayedCard)">@game.LastPlayedCard.ToDisplay(Model.Culture)</b>
        </p>
    }

    @if (game.Phase == TarotPhase.Playing && (game.CanDeclarePoignee(viewer) || game.CanAnnounceSlam(viewer)))
    {
        <p style="margin:4px 0">
            @if (game.CanAnnounceSlam(viewer))
            {
                <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tarotchelem @Model.RoomId,">@GetString("tarot_announce_slam_button")</button>
            }
            @if (game.CanDeclarePoignee(viewer))
            {
                <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tarotpoignee @Model.RoomId,">@GetString("tarot_declare_poignee_button", GetString($"tarot_poignee_tier_{game.GetDeclarablePoigneeTier(viewer)}"))</button>
            }
        </p>
    }

    <p style="margin:6px 0;line-height:2.4em">
        @foreach (var card in Model.ViewerHand)
        {
            var color = CardColor(card);
            var baseStyle = $"display:inline-block;margin:2px;padding:{CardPadding(card)};font-size:{CardFontSize(card)};font-weight:bold;border-radius:4px;background:#f3eef8;color:{color}";
            if (game.Phase == TarotPhase.Discard && isTaker)
            {
                if (card.IsKing || card.IsOudler)
                {
                    <span style="@baseStyle;opacity:0.4">@card.ToDisplay(Model.Culture)</span>
                }
                else
                {
                    var selected = game.PendingDiscards.Contains(card);
                    <button name="send" value="@Action("tarotdiscard", card)"
                            style="@baseStyle;cursor:pointer;@(selected ? "outline:3px solid #f7a000" : "")">@card.ToDisplay(Model.Culture)</button>
                }
            }
            else if (game.Phase == TarotPhase.Playing && isViewerTurn)
            {
                if (Model.ViewerLegalMoves.Contains(card))
                {
                    <button name="send" value="@Action("tp", card)" style="@baseStyle;cursor:pointer">@card.ToDisplay(Model.Culture)</button>
                }
                else
                {
                    <span style="@baseStyle;opacity:0.35">@card.ToDisplay(Model.Culture)</span>
                }
            }
            else
            {
                <span style="@baseStyle">@card.ToDisplay(Model.Culture)</span>
            }
        }
    </p>

    @if (game.Phase == TarotPhase.Playing && !isViewerTurn && game.CurrentPlayer != null)
    {
        <p style="margin:4px 0;color:#9a8caa;font-size:0.85em">
            @GetString("tarot_waiting_for") <b>@game.CurrentPlayer.Name</b>
        </p>
    }

    <details style="margin:8px 0 0 0">
        <summary style="cursor:pointer;font-size:0.8em;color:#9a8caa">@GetString("tarot_options")</summary>
        <p style="margin:8px 0 0 0;text-align:right">
            <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tarotsub @Model.RoomId" style="font-size:0.8em">
                @(viewer != null && viewer.WantsSub ? GetString("tarot_sub_cancel_button") : GetString("tarot_sub_request_button"))
            </button>
        </p>
    </details>
</div>
