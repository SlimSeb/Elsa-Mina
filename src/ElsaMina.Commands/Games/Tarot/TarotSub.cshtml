@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Tarot.TarotViewModel>
@using ElsaMina.Core.Utils

<div style="background:#3a2535;color:#ece7f2;border:1px solid #6a4a5a;border-radius:6px;padding:8px">
    <h4 style="margin:0 0 6px 0;text-align:center">🔁 @GetString("tarot_sub_panel_title")</h4>
    <p style="text-align:center;margin:4px 0">@GetString("tarot_sub_panel_intro")</p>
    <p style="text-align:center;margin:6px 0">
        @foreach (var player in Model.Game.Players.Where(currentPlayer => currentPlayer.WantsSub))
        {
            <button class="button" name="send" value="@(Model.Trigger)tarotsubaccept @player.UserId" style="margin:2px">
                @GetString("tarot_sub_panel_take", player.Name)
            </button>
        }
    </p>
</div>
