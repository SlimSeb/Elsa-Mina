@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Tarot.TarotViewModel>
@using ElsaMina.Commands.Games.Tarot
@using ElsaMina.Core.Utils

@{
    var game = Model.Game;
    var result = game.ScoreResult;

    string CardColor(TarotCard card)
    {
        if (card.IsExcuse)
        {
            return "#8fd694";
        }
        if (card.IsTrump)
        {
            return "#7fc4ff";
        }
        return card.Suit is TarotSuit.Hearts or TarotSuit.Diamonds ? "#ff7b7b" : "#ececec";
    }

    string CardSize(TarotCard card) => card.IsExcuse ? "1.45em" : "1.15em";

    string SideLabel(int side) => GetString(side >= 0 ? "tarot_side_attack" : "tarot_side_defense");
    string Points(int halfPoints) => (Math.Abs(halfPoints) / 2.0).ToString("0.#", Model.Culture);
}

<div style="background:#2d2535;color:#ece7f2;border:1px solid #5a4a6a;border-radius:6px;padding:10px">
    <h3 style="margin:0 0 8px 0;text-align:center">🃏 @GetString("tarot_result_title")</h3>

    @if (result == null)
    {
        <p style="text-align:center">@GetString("tarot_result_no_score")</p>
    }
    else
    {
        <p style="text-align:center;margin:4px 0">
            <b style="color:@game.Taker?.Name.ToColorHexCodeWithCustoms()">@game.Taker?.Name</b>
            (@GetString($"tarot_bid_{game.HighestBid.ToString().ToLowerInvariant()}"))
            @if (game.Partner != null)
            {
                <text>&amp; <b style="color:@game.Partner.Name.ToColorHexCodeWithCustoms()">@game.Partner.Name</b></text>
            }
        </p>

        <p style="text-align:center;margin:4px 0;font-size:1.1em">
            @if (result.Made)
            {
                <b style="color:#6ddf9a">@GetString("tarot_result_contract_made")</b>
            }
            else
            {
                <b style="color:#ff7b7b">@GetString("tarot_result_contract_failed")</b>
            }
        </p>

        <p style="text-align:center;margin:4px 0">
            @GetString("tarot_result_points",
                (result.TakerHalfPoints / 2.0).ToString("0.#", Model.Culture),
                (result.TargetHalfPoints / 2.0).ToString("0.#", Model.Culture),
                result.OudlerCount)
        </p>
        <p style="text-align:center;margin:4px 0;color:#b9a9c9">
            @GetString("tarot_result_breakdown",
                (result.BaseHalfPoints / 2.0).ToString("0.#", Model.Culture),
                result.Multiplier,
                (result.ContractValueHalfPoints / 2.0).ToString("0.#", Model.Culture))
        </p>

        @if (result.PetitAuBoutSide != 0)
        {
            <p style="text-align:center;margin:2px 0;color:#f7d774;font-size:0.9em">
                @GetString("tarot_result_petit_au_bout", Points(result.PetitAuBoutHalfPoints), SideLabel(result.PetitAuBoutSide))
            </p>
        }
        @if (result.PoigneeHalfPoints > 0)
        {
            <p style="text-align:center;margin:2px 0;color:#f7d774;font-size:0.9em">
                @GetString("tarot_result_poignee", Points(result.PoigneeHalfPoints), SideLabel(result.Made ? 1 : -1))
            </p>
        }
        @if (result.SlamWinnerSide != 0 || result.SlamAnnounced)
        {
            <p style="text-align:center;margin:2px 0;color:#f7d774;font-size:0.9em">
                @if (result.SlamWinnerSide != 0)
                {
                    <text>@GetString("tarot_result_slam_made", Points(result.SlamHalfPoints), SideLabel(result.SlamWinnerSide))</text>
                }
                else
                {
                    <text>@GetString("tarot_result_slam_failed", Points(result.SlamHalfPoints))</text>
                }
            </p>
        }

        <table style="margin:8px auto 0 auto;border-collapse:collapse">
            <tr style="border-bottom:1px solid #5a4a6a">
                <th style="padding:2px 12px;text-align:left">@GetString("tarot_players_label")</th>
                <th style="padding:2px 12px">@GetString("tarot_result_score_label")</th>
            </tr>
            @for (var i = 0; i < game.Players.Count; i++)
            {
                var player = game.Players[i];
                var delta = i < result.Deltas.Length ? result.Deltas[i] / 2.0 : 0;
                var color = delta >= 0 ? "#6ddf9a" : "#ff7b7b";
                <tr>
                    <td style="padding:2px 12px;color:@player.Name.ToColorHexCodeWithCustoms()">@player.Name</td>
                    <td style="padding:2px 12px;text-align:center;font-weight:bold;color:@color">
                        @(delta >= 0 ? "+" : "")@delta.ToString("0.#", Model.Culture)
                    </td>
                </tr>
            }
        </table>

        <details style="margin-top:12px">
            <summary style="cursor:pointer;text-align:center;font-weight:bold">@GetString("tarot_cards_won_title")</summary>
            @foreach (var player in game.Players)
            {
                var capturedPoints = player.CapturedPile.Sum(card => card.HalfPoints) / 2.0;
                var orderedCards = player.CapturedPile
                    .OrderBy(card => card.Suit)
                    .ThenBy(card => card.Rank)
                    .ToList();
                <div style="margin:6px 0;padding:5px 8px;background:#241d2d;border-radius:5px">
                    <span style="color:@player.Name.ToColorHexCodeWithCustoms();font-weight:bold">@player.Name</span>
                    <span style="color:#b9a9c9">(@GetString("tarot_cards_won_points", capturedPoints.ToString("0.#", Model.Culture)))</span>
                    <div style="margin-top:3px;line-height:1.9em">
                        @if (orderedCards.Count == 0)
                        {
                            <span style="color:#7a6b8a">&mdash;</span>
                        }
                        else
                        {
                            foreach (var card in orderedCards)
                            {
                                <span style="color:@CardColor(card);font-weight:bold;font-size:@CardSize(card);margin:0 3px">@card.ToDisplay(Model.Culture)</span>
                            }
                        }
                    </div>
                </div>
            }
        </details>
    }
</div>
