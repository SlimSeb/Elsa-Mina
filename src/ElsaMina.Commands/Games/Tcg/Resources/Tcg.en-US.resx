    <data name="tcg_cards_help" xml:space="preserve">
        <value>Syntax: tcgcards [deckName]. Shows the full card pool. Pass one of your deck names to get "+" buttons that add cards to it.</value>
    </data>
    <data name="tcg_deck_help" xml:space="preserve">
        <value>Syntax: tcgdeck [name]. With no name, lists your decks; with a name, opens that deck's builder.</value>
    </data>
    <data name="tcg_decknew_help" xml:space="preserve">
        <value>Syntax: tcgdecknew &lt;name&gt;. Creates a new, empty deck.</value>
    </data>
    <data name="tcg_deckadd_help" xml:space="preserve">
        <value>Syntax: tcgdeckadd &lt;deck&gt;, &lt;cardId&gt;. Adds a card to a deck.</value>
    </data>
    <data name="tcg_deckremove_help" xml:space="preserve">
        <value>Syntax: tcgdeckremove &lt;deck&gt;, &lt;cardId&gt;. Removes a card from a deck.</value>
    </data>
    <data name="tcg_deckenergy_help" xml:space="preserve">
        <value>Syntax: tcgdeckenergy &lt;deck&gt;, &lt;type&gt; [type] [type]. Sets the deck's Energy Zone types (1-3).</value>
    </data>
    <data name="tcg_deckdelete_help" xml:space="preserve">
        <value>Syntax: tcgdeckdelete &lt;name&gt;. Deletes one of your decks.</value>
    </data>

