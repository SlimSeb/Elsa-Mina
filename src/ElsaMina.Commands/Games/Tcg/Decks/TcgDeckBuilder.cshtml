@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Games.Tcg.Decks.TcgDeckBuilderViewModel>
@using ElsaMina.Commands.Games.Tcg.Cards
@using ElsaMina.Commands.Games.Tcg.Decks
@using ElsaMina.Core.Services.Templates

@{
    var deck = Model.Deck;
    var cards = deck.Cards;
    var counts = cards.GroupBy(id => id).ToDictionary(group => group.Key, group => group.Count());
    var total = cards.Count;
    var isFull = total >= Model.DeckSize;
    var selectedEnergy = deck.EnergyTypes
        .Select(name => TcgTypes.TryParse(name, out var parsed) ? parsed : (TcgType?)null)
        .Where(parsed => parsed.HasValue)
        .Select(parsed => parsed.Value)
        .ToList();

    string TypeBadge(TcgType type) =>
        $"<span style=\"display:inline-block;width:15px;height:15px;line-height:15px;text-align:center;border-radius:50%;font-size:0.7em;font-weight:bold;color:#fff;background:{TcgTypeStyle.Color(type)}\">{TcgTypeStyle.Symbol(type)}</span>";

    string EnergyPips(IReadOnlyList<TcgType> cost)
    {
        if (cost.Count == 0)
        {
            return "<span style=\"color:#888\">—</span>";
        }
        return string.Join(" ", cost.Select(TypeBadge));
    }

    // Renders the visual face of a card (header, art, attacks, footer) as a self-contained block.
    // The caller wraps it in a tile and appends the add/remove action button.
    string CardFace(TcgCard card)
    {
        var attacks = string.Join("", card.Attacks.Select(attack =>
            $"<div style=\"margin:2px 0;font-size:0.72em\">{EnergyPips(attack.Cost)} <b>{attack.Name}</b>" +
            (attack.Damage > 0 ? $"<span style=\"float:right;color:#333;font-weight:bold\">{attack.Damage}</span>" : "") +
            "</div>"));

        var exBadge = card.IsEx ? "<span style=\"color:#ffe680\"> ex</span>" : string.Empty;
        var weakness = card.Weakness.HasValue ? $"&nbsp;⚠{TypeBadge(card.Weakness.Value)}" : string.Empty;

        return
            $"<div style=\"background:{TcgTypeStyle.Color(card.Type)};color:#fff;border-radius:7px 7px 0 0;padding:3px 6px;font-size:0.8em;font-weight:bold;overflow:hidden\">" +
                $"{card.Name}{exBadge}<span style=\"float:right\">{card.Hp} HP</span></div>" +
            $"<div style=\"text-align:center;padding:2px\"><img src=\"{card.SpriteUrl}\" width=\"60\" height=\"60\" alt=\"{card.Name}\"/></div>" +
            $"<div style=\"padding:3px 6px;min-height:34px\">{attacks}</div>" +
            "<div style=\"padding:2px 6px;font-size:0.7em;color:#555;border-top:1px solid #e2e2e2;overflow:hidden\">" +
                $"{TypeBadge(card.Type)}{weakness}<span style=\"float:right\">↩{card.RetreatCost}</span></div>";
    }
}

<div style="border:1px solid @StyleConstants.PRIMARY_BORDER_COLOR;border-radius:10px;padding:8px">
    <h3 style="margin:0 0 4px 0">🛠️ @GetString("tcg_builder_title", deck.Name)</h3>

    <p style="margin:4px 0">
        <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tcgdeck">← @GetString("tcg_builder_back")</button>
    </p>

    <p style="margin:4px 0">
        <b>@GetString("tcg_builder_count")</b>:
        <span style="font-weight:bold;color:@(total == Model.DeckSize ? "#3fa34d" : "#e8923a")">@total / @Model.DeckSize</span>
        &nbsp;|&nbsp;
        @if (Model.Validation.IsValid)
        {
            <span style="color:#3fa34d;font-weight:bold">✓ @GetString("tcg_builder_legal")</span>
        }
        else
        {
            <span style="color:#cc2b2b;font-weight:bold">✗ @GetString(Model.Validation.ErrorKey, Model.Validation.Args ?? new object[] { })</span>
        }
    </p>

    <p style="margin:4px 0">
        <b>@GetString("tcg_builder_energy_zone")</b>:
        @foreach (var type in Model.SelectableEnergyTypes)
        {
            var isOn = selectedEnergy.Contains(type);
            <button class="button@(isOn ? " disabled" : "")" name="send" value="/w @Model.BotName, @(Model.Trigger)tcgdeckenergytoggle @deck.Name, @type"
                    style="margin:1px;@(isOn ? $"background:{TcgTypeStyle.Color(type)};color:#fff;" : "")">
                @GetString(type.NameKey())
            </button>
        }
    </p>

    <h4 style="margin:8px 0 2px 0">@GetString("tcg_builder_contents")</h4>
    @if (total == 0)
    {
        <p style="color:#888;margin:2px 0"><em>@GetString("tcg_builder_empty")</em></p>
    }
    else
    {
        <div>
            @foreach (var entry in counts.OrderBy(item => item.Key))
            {
                var resolved = TcgCardPool.TryGet(entry.Key, out var card);
                <div style="display:inline-block;vertical-align:top;width:148px;margin:3px;border:1px solid @StyleConstants.PRIMARY_BORDER_COLOR;border-radius:8px;overflow:hidden;background:transparent">
                    @if (resolved)
                    {
                        @Raw(CardFace(card))
                    }
                    else
                    {
                        <div style="padding:8px;text-align:center;color:#c0392b;font-weight:bold">@entry.Key</div>
                    }
                    <div style="text-align:center;padding:3px;border-top:1px solid #e2e2e2">
                        <span style="font-weight:bold;color:#555">x@(entry.Value)</span>
                        <button class="button" name="send" value="/w @Model.BotName, @(Model.Trigger)tcgdeckremove @deck.Name, @entry.Key">−</button>
                    </div>
                </div>
            }
        </div>
    }

    <h4 style="margin:10px 0 2px 0">@GetString("tcg_builder_pool")</h4>
    <div>
        @foreach (var card in Model.AllCards)
        {
            var copies = counts.GetValueOrDefault(card.Id, 0);
            var atMax = copies >= Model.MaxCopies;
            var disabled = isFull || atMax;
            <div style="display:inline-block;vertical-align:top;width:148px;margin:3px;border:1px solid @StyleConstants.PRIMARY_BORDER_COLOR;border-radius:8px;overflow:hidden;background:transparent">
                @Raw(CardFace(card))
                <div style="text-align:center;padding:3px;border-top:1px solid #e2e2e2">
                    <span style="color:#888;font-size:0.8em">@copies/@Model.MaxCopies</span>
                    <button class="button@(disabled ? " disabled" : "")" name="send" value="/w @Model.BotName, @(Model.Trigger)tcgdeckadd @deck.Name, @card.Id">+</button>
                </div>
            </div>
        }
    </div>
</div>
