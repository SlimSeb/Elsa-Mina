@using ElsaMina.Core.Services.Templates
@using ElsaMina.Core.Utils
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Tournaments.Betting.BettingAnnouncementViewModel>

@{
    const int columns = 3;
    const string cellStyle = "vertical-align: top;" +
                             "width: 220px;" +
                             "padding: 2px 8px;" +
                             "box-sizing: border-box;";
}

<div
    style="border: 1px solid @StyleConstants.PRIMARY_BORDER_COLOR; border-radius: 8px; padding: 8px; box-sizing: border-box">
    <b style="display: block; margin-bottom: 4px; border-bottom: 1px solid @StyleConstants.PRIMARY_BORDER_COLOR; padding-bottom: 4px">
        @GetString("betting_announcement_title")
    </b>
    @if (Model.IsBettingOpen)
    {
        <i style="display: block; font-size: 0.85em; margin-bottom: 6px; color: gray">
            @GetString("betting_announcement_closes_in", Model.SecondsToClose)
        </i>
    }
    else
    {
        <i style="display: block; font-size: 0.85em; margin-bottom: 6px; color: gray">
            @GetString("betting_announcement_closed")
        </i>
    }
    <table style="table-layout: fixed; border-collapse: collapse">
        <tbody>
        @for (var rowStart = 0; rowStart < Model.Players.Length; rowStart += columns)
        {
            <tr>
                @for (var column = 0; column < columns; column++)
                {
                    var index = rowStart + column;
                    if (index >= Model.Players.Length)
                    {
                        <td style="@cellStyle"></td>
                        continue;
                    }
                    var player = Model.Players[index];
                    var bettors = Model.BetsByPlayer != null && Model.BetsByPlayer.TryGetValue(player.UserId, out var list) ? list : [];
                    <td style="@cellStyle">
                        <span
                            class="username"
                            data-name="@player.UserId"
                            style="color: @player.UserId.ToColorHexCodeWithCustoms(); display: inline-block; width: 110px; margin-right: 8px; vertical-align: middle; overflow: hidden; text-overflow: ellipsis; white-space: nowrap">
                            @player.UserName
                        </span>
                        @if (Model.IsBettingOpen)
                        {
                            <button class="button" name="send"
                                    value="/pm @Model.BotName, @(Model.Trigger)bet @Model.RoomId @player.UserId">@GetString("betting_announcement_bet_button")</button>
                        }
                        @if (bettors.Count > 0)
                        {
                            <div style="font-size: 0.85em; color: gray">
                                @string.Join(", ", bettors)
                            </div>
                        }
                    </td>
                }
            </tr>
        }
        </tbody>
    </table>
</div>
