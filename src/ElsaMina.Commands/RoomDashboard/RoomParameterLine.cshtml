@using ElsaMina.Core.Services.Rooms
@using ElsaMina.Core.Services.Rooms.Parameters
@using ElsaMina.Core.Services.Templates
@using ElsaMina.Core.Utils
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.RoomDashboard.RoomParameterLineModel>

@{
    const string rowStyle = $"border-bottom: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR};";
    const string labelCellStyle = "padding: 10px 14px; vertical-align: middle;";
    const string controlCellStyle = "padding: 10px 14px; vertical-align: middle; text-align: center; width: 1%; white-space: nowrap;";
    const string nameStyle = "font-weight: bold; font-size: 0.9em; display: block;";
    const string descStyle = $"font-size: 0.78em; color: {StyleConstants.PRIMARY_BORDER_COLOR}; margin-top: 2px; display: block;";
    const string selectStyle = $"border: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR}; border-radius: 3px;" +
                               "padding: 3px 6px; font-size: 0.85em; max-width: 140px;";
    const string inputStyle = $"border: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR}; border-radius: 3px;" +
                              "padding: 3px 6px; font-size: 0.85em; width: 100%; box-sizing: border-box;";
}
<tr style="@rowStyle">
    <td style="@labelCellStyle">
        <label for="@Model.RoomParameterDefinition.Identifier">
            <span style="@nameStyle">@GetString(Model.RoomParameterDefinition.NameKey)</span>
            <span style="@descStyle">@GetString(Model.RoomParameterDefinition.DescriptionKey)</span>
        </label>
    </td>
    <td style="@controlCellStyle">
        @switch (Model.RoomParameterDefinition.Type)
        {
            case RoomBotConfigurationType.Enumeration:
            {
                <select
                    name="@Model.RoomParameterDefinition.Identifier"
                    id="@Model.RoomParameterDefinition.Identifier"
                    style="@selectStyle">
                    @foreach (var option in Model.RoomParameterDefinition.PossibleValues)
                    {
                        <option
                            value="@option.InternalValue"
                            @(string.Equals(option.InternalValue, Model.CurrentValue, StringComparison.InvariantCultureIgnoreCase) ? "selected" : string.Empty)>
                            @option.DisplayedValue
                        </option>
                    }
                </select>
                break;
            }
            case RoomBotConfigurationType.Boolean:
                <input
                    type="checkbox"
                    id="@Model.RoomParameterDefinition.Identifier"
                    name="@Model.RoomParameterDefinition.Identifier"
                    @(Model.CurrentValue.ToBoolean() ? "checked" : string.Empty)/>
                break;
            case RoomBotConfigurationType.String:
                <input
                    type="text"
                    id="@Model.RoomParameterDefinition.Identifier"
                    name="@Model.RoomParameterDefinition.Identifier"
                    value="@Model.CurrentValue"
                    style="@inputStyle"/>
                break;
        }
    </td>
</tr>