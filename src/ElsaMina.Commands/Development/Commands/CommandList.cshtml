@using ElsaMina.Core.Services.Rooms
@using ElsaMina.Core.Services.Templates
@inherits ElsaMina.Core.Services.Templates.LocalizableTemplatePage<ElsaMina.Commands.Development.Commands.CommandListViewModel>

@{
    const string border = $"border: 1px solid {StyleConstants.PRIMARY_BORDER_COLOR};";
    const string headerStyle = $"{border} padding: 4px 8px; text-align: left; background-color: {StyleConstants.PRIMARY_BACKGROUND_COLOR};";
    const string cellStyle = $"{border} padding: 6px 8px; vertical-align: top;";

    string RankColor(Rank rank) => rank switch
    {
        Rank.Admin or Rank.Leader => "#c62828",
        Rank.RoomOwner             => "#e65100",
        Rank.Mod                   => "#1565c0",
        Rank.Driver                => "#9836d4",
        Rank.Voiced                => "#2e7d32",
        _                          => "#999",
    };

    string FlagBadge(string text, string bg, string fg = "#fff") =>
        $"<span style=\"padding:2px;background:{bg};color:{fg};margin-left:4px;\">{text}</span>";

    string NavCommand(int index) => $"/w {Model.BotName},{Model.Trigger}allcommands {index}";
    string MenuCommand() => $"/w {Model.BotName},{Model.Trigger}allcommands";
}

<div style="padding: 1rem;">
    @if (Model.CurrentCategoryIndex < 0)
    {
        <div style="font-size: 1.05rem; font-weight: bold; margin-bottom: 0.75rem;">
            @GetString("allcommands_pick_category")
        </div>
        <div>
            @for (var i = 0; i < Model.Categories.Count; i++)
            {
                var index = i;
                var count = Model.Commands.Count(c => (string.IsNullOrEmpty(c.Category) ? "Other" : c.Category) == Model.Categories[index]);
                <div style="margin-bottom: 0.4rem;">
                    <button class="button" name="send" value="@NavCommand(index)">
                        @Model.Categories[index] <span style="font-size:0.8rem;">(@count)</span>
                    </button>
                </div>
            }
        </div>
    }
    else
    {
        var currentCategory = Model.Categories[Model.CurrentCategoryIndex];
        var currentCommands = Model.Commands
            .Where(c => (string.IsNullOrEmpty(c.Category) ? "Other" : c.Category) == currentCategory)
            .OrderBy(c => c.Name)
            .ToList();

        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
            <button class="button" name="send" value="@MenuCommand()">&#8592; @GetString("allcommands_back")</button>
            <span style="font-size: 1.05rem; font-weight: bold;">@currentCategory</span>
            <span style="font-size: 0.85rem; color: #666;">(@currentCommands.Count)</span>
        </div>

        <table style="border-collapse: collapse; width: 100%;">
            <thead>
            <tr>
                <th style="@headerStyle">@GetString("allcommands_name")</th>
                <th style="@headerStyle">@GetString("allcommands_required_rank")</th>
                <th style="@headerStyle">@GetString("allcommands_flags")</th>
                <th style="@headerStyle">@GetString("allcommands_description")</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var command in currentCommands)
            {
                <tr>
                    <td style="@cellStyle">
                        <b>@command.Name</b>
                        @if (command.Aliases.Any())
                        {
                            <div style="font-size: 0.8rem; margin-top: 2px;">
                                @string.Join(", ", command.Aliases)
                            </div>
                        }
                    </td>
                    <td style="@cellStyle white-space:nowrap;">
                        <span style="color: @RankColor(command.RequiredRank); font-weight: bold;">
                            @User.GetCharacterFromRank(command.RequiredRank)
                        </span>
                    </td>
                    <td style="@cellStyle white-space:nowrap;">
                        @if (command.IsAllowedInPrivateMessage)
                        {
                            @Raw(FlagBadge("PM", "#0277bd"))
                        }
                        @if (command.IsPrivateMessageOnly)
                        {
                            @Raw(FlagBadge("PM only", "#01579b"))
                        }
                        @if (command.IsWhitelistOnly)
                        {
                            @Raw(FlagBadge("WL", "#558b2f"))
                        }
                        @if (command.RoomRestriction.Any())
                        {
                            @Raw(FlagBadge(string.Join(", ", command.RoomRestriction), "#4e342e"))
                        }
                    </td>
                    <td style="@cellStyle font-size: 0.85rem; font-style: italic;">
                        @if (!string.IsNullOrEmpty(command.HelpMessageKey))
                        {
                            @GetString(command.HelpMessageKey)
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
